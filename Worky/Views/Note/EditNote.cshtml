@model Worky.Models.Project.NoteEditModel

@{
    ViewData["Title"] = "EditNote";
}

<h1>Редакто</h1>
<hr />

<h4>NoteEditModel</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="EditNote">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Id" class="control-label" hidden></label>
                <input asp-for="Id" class="form-control" hidden/>
                <span asp-validation-for="Id" class="text-danger" hidden></span>
            </div>
            <div class="form-group">
                <label asp-for="ProjectId" class="control-label" hidden></label>
                <input asp-for="ProjectId" class="form-control" hidden/>
                <span asp-validation-for="ProjectId" class="text-danger" hidden></span>
            </div>
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a href="/Notes/ProjectNotes?ProjectId=@Model.ProjectId">К заметкам</a>
</div>

