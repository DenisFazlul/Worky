@model Worky.Models.Project.ProjectModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<div>
    <h4>ProjectModel</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Id)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Id)
        </dd>
    </dl>
</div>
<div>
    @Html.ActionLink("Edit", "Edit", new { /* id = Model.PrimaryKey */ }) |
    <a asp-action="Index">Back to List</a>
</div>
<a href="/Invite/Add?ProjectId=@Model.Id">Добавить пользователя</a>
<br />
<hr />
@foreach(Worky.Project.Invite i in @Model.Invites)
{
   
    <a>@i.Name</a>
    <a href="/Invite/Remove?ProjectId=@Model.Id&&InviteId=@i.Id">Удалить</a>
}